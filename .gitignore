/target
.agent/runs/
.agent/patches/
.agent/logs/
.env
.env.*
node_modules/
dist/
coverage/

# Python build/test artifacts (bingen pyo3 backend + SDK)
.venv/
__pycache__/
*.egg-info/
.pytest_cache/
*.whl
*.abi3.so
*.pyd
sdk/python/autoagent/_native*

crates/autoagent-bingen/deno.lock
sdk/deno/deno.lock

# deno_bindgen-generated TS bindings (downstream artifact of deno_bindgen.rs;
# regenerate with `deno run -A crates/autoagent-bingen/deno/gen.ts ...`). The
# Rust backend src/deno/deno_bindgen.rs IS drift-checked; this output is not.
crates/autoagent-bingen/bindings/

# autoagent-bingen emits drift-checked golden files into dist/ (type stubs +
# loader shims) that MUST be tracked; only the compiled binaries are ignored.
!crates/autoagent-bingen/dist/
crates/autoagent-bingen/dist/*.node
crates/autoagent-bingen/dist/*.wasm
crates/autoagent-bingen/dist/*.dylib
crates/autoagent-bingen/dist/*.so
crates/autoagent-bingen/dist/*.dll
*.log
*.tsbuildinfo
.idea/
.vscode/
.DS_Store
*.swp
*.swo
*.bak
*.tmp
*.env
*.env.*
*.local
*.pem
*.key
*.crt
*.pfx

# Node SDK lockfile uses a local file: dep path
sdk/node/package-lock.json
